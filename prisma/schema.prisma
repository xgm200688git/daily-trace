generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            Int               @id @default(autoincrement())
  email         String            @unique
  passwordHash  String            @map("password_hash")
  createdAt     String            @map("created_at")
  updatedAt     String            @map("updated_at")
  profileSettings ProfileSettings?
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique
  expiresAt String   @map("expires_at")
  createdAt String   @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model ProfileSettings {
  id                Int         @id @default(autoincrement())
  userId            Int?        @map("user_id") @unique
  timezone          String
  weekStartsOn      Int         @map("week_starts_on")
  aiEnabled         Int         @map("ai_enabled") @default(0)
  defaultTemplateId String?     @map("default_template_id")
  createdAt         String      @map("created_at")
  updatedAt         String      @map("updated_at")
  user              User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  templates         Template[]
  entries           Entry[]
  dailyRecords      DailyRecord[]
  weeklyReports     WeeklyReport[]
  jobRuns           JobRun[]

  @@map("profile_settings")
  @@index([userId])
}

model Template {
  id             String         @id
  profileId      Int            @map("profile_id")
  name           String
  version        Int            @default(1)
  isDefault      Int            @map("is_default") @default(0)
  definitionJson String         @map("definition_json")
  createdAt      String         @map("created_at")
  updatedAt      String         @map("updated_at")
  profile        ProfileSettings @relation(fields: [profileId], references: [id], onDelete: Cascade)
  weeklyReports  WeeklyReport[]

  @@map("templates")
  @@index([profileId, isDefault])
}

model Entry {
  id                   String         @id
  profileId            Int            @map("profile_id")
  module               String
  occurredAt           String         @map("occurred_at")
  localDate            String         @map("local_date")
  title                String?
  content              String
  mood                 String?
  tagsJson             String?        @map("tags_json")
  taskStatus           String?        @map("task_status")
  completedAt          String?        @map("completed_at")
  completedLocalDate   String?        @map("completed_local_date")
  deletedAt            String?        @map("deleted_at")
  createdAt            String         @map("created_at")
  updatedAt            String         @map("updated_at")
  profile              ProfileSettings @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("entries")
  @@index([profileId, module, localDate])
  @@index([profileId, module, completedLocalDate])
}

model DailyRecord {
  id              String         @id
  profileId       Int            @map("profile_id")
  module          String
  recordDate      String         @map("record_date")
  contentMarkdown String         @map("content_markdown")
  contentJson     String         @map("content_json")
  sourceIdsJson   String         @map("source_ids_json")
  sourceHash      String         @map("source_hash")
  generatorMode   String         @map("generator_mode")
  generatedAt     String         @map("generated_at")
  updatedAt       String         @map("updated_at")
  profile         ProfileSettings @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("daily_records")
  @@unique([profileId, module, recordDate])
  @@index([profileId, recordDate])
}

model WeeklyReport {
  id                String         @id
  profileId         Int            @map("profile_id")
  templateId        String?        @map("template_id")
  weekStart         String         @map("week_start")
  weekEnd           String         @map("week_end")
  revision          Int
  isCurrent         Int            @map("is_current") @default(1)
  contentMarkdown   String         @map("content_markdown")
  sectionsJson      String         @map("sections_json")
  sourceRecordIdsJson String        @map("source_record_ids_json")
  sourceHash        String         @map("source_hash")
  generatorMode     String         @map("generator_mode")
  generatedAt       String         @map("generated_at")
  createdAt         String         @map("created_at")
  profile           ProfileSettings @relation(fields: [profileId], references: [id], onDelete: Cascade)
  template          Template?      @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@map("weekly_reports")
  @@unique([profileId, weekStart, revision])
  @@index([profileId, weekStart, isCurrent])
}

model JobRun {
  id            String         @id
  profileId     Int            @map("profile_id")
  type          String
  jobKey        String         @map("job_key") @unique
  status        String
  lastSuccessAt String?        @map("last_success_at")
  lastError     String?        @map("last_error")
  startedAt     String         @map("started_at")
  finishedAt    String?        @map("finished_at")
  createdAt     String         @map("created_at")
  updatedAt     String         @map("updated_at")
  profile       ProfileSettings @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("job_runs")
  @@index([profileId, type, updatedAt])
}
